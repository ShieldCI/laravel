{
    "name": "shieldci/laravel",
    "description": "Automated code analysis for Laravel applications covering security, performance, reliability, code quality and best practices.",
    "keywords": [
        "laravel",
        "security",
        "performance",
        "reliability",
        "code-quality",
        "best-practices",
        "static-analysis",
        "vulnerability-scanner",
        "enlightn",
        "enlightn-alternative",
        "shieldci"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "ShieldCI",
            "email": "support@shieldci.com"
        }
    ],
    "homepage": "https://docs.shieldci.com",
    "support": {
        "docs": "https://docs.shieldci.com",
        "issues": "https://github.com/ShieldCI/laravel/issues",
        "source": "https://github.com/ShieldCI/laravel"
    },
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "larastan/larastan": "^2.0|^3.0",
        "phpstan/phpstan": "^1.10|^2.0",
        "shieldci/analyzers-core": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "ShieldCI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ShieldCI\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage --coverage-text --coverage-clover=coverage.xml",
        "test-coverage-check": "vendor/bin/phpunit --coverage-text --coverage-clover=coverage.xml --coverage-filter src/ --fail-on-risky --fail-on-warning",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test",
        "check": [
            "@format-check",
            "@analyse",
            "@test"
        ],
        "quality": [
            "@format",
            "@analyse",
            "@test-coverage"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "ShieldCI\\ShieldCIServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "audit": {
            "ignore": {
                "PKSA-8qx3-n5y5-vvnd": "Dev-only: Laravel framework advisory pulled via orchestra/testbench for testing older Laravel versions",
                "PKSA-w7xr-vk7n-rstm": "Dev-only: Laravel framework advisory pulled via orchestra/testbench for testing older Laravel versions",
                "PKSA-mdq4-51ck-6kdq": "Dev-only: Laravel framework advisory pulled via orchestra/testbench for testing older Laravel versions",
                "PKSA-q46n-4fdk-zjr4": "Dev-only: Laravel framework advisory pulled via orchestra/testbench for testing older Laravel versions",
                "PKSA-qzrn-rnz3-85w1": "Dev-only: Laravel framework advisory pulled via orchestra/testbench for testing older Laravel versions"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
